; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="minigame"
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

App="*res://autoload/App.gd"
Net="*res://autoload/Net.gd"
BattleStateManager="*res://autoload/BattleStateManager.gd"
TerritoryClaimState="*res://autoload/TerritoryClaimState.gd"
NetworkManager="*res://autoload/net/NetworkManager.gd"
PlayerDataSync="*res://autoload/net/PlayerDataSync.gd"
PhaseController="*res://autoload/net/PhaseController.gd"
PhaseSync="*res://autoload/net/PhaseSync.gd"
BattleSync="*res://autoload/net/BattleSync.gd"
TerritorySync="*res://autoload/net/TerritorySync.gd"
TerritoryClaimManager="*res://autoload/TerritoryClaimManager.gd"
WinConditionManager="*res://autoload/WinConditionManager.gd"
CardEnlargeOverlay="*res://autoload/CardEnlargeOverlay.gd"

[display]

window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/sicilica.import.pixelorama/plugin.cfg")

